function selectFont(fontFamily = "Candara" , Style = "Regular" , Size = "11"){
  logStep("Changing font family : " + fontFamily + " with style : " + Style + " and size : " + Size);
  clickElement(Aliases.Notepad.PopupHost.InputSiteWindowClass.Popup.Item.Font);
  clickElement(Aliases.Notepad.wndNotepad.Microsoft_UI_Content_DesktopChildSiteBridge.InputSiteWindowClass.RootScrollViewer.Font.Font.Family_2);
  pressDelete();
  typeText(Aliases.Notepad.wndNotepad.Microsoft_UI_Content_DesktopChildSiteBridge.InputSiteWindowClass.RootScrollViewer.Font.Font.Family_2, fontFamily);
  typeText(Aliases.Notepad.wndNotepad.Microsoft_UI_Content_DesktopChildSiteBridge.InputSiteWindowClass.RootScrollViewer.Font.Font.Style_2 , Style);
  typeText(Aliases.Notepad.wndNotepad.Microsoft_UI_Content_DesktopChildSiteBridge.InputSiteWindowClass.RootScrollViewer.Font.Font.Size_2, Size);
  pressBackspace();
}


