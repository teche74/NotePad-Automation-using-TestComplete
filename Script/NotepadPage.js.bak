  logStep("Closing Notepad");
  
  closeWindow(Aliases.Notepad.wndNotepad);
}

function verifyApplicationOpen(){
  logStep("Verifying Notepad is open");
  return verifyObjectExists(
      Aliases.Notepad.wndNotepad
  );
}

function verifyApplicationClosed(){

    logStep("Verifying Notepad is closed");

    if(!Aliases.Notepad.wndNotepad.Exists){

        logPass("Notepad application closed successfully");
        return true;

    }

    logError("Notepad application is still open");
    return false;
}


function checkFileExist(fileName){
  logStep("Checking whether file exists : " + FILE_SAVE_PATH + fileName + '.txt');
  
  if(aqFileSystem.Exists(FILE_SAVE_PATH + fileName + '.txt')){
    Log.Checkpoint("File exists : " + FILE_SAVE_PATH + fileName + '.txt');
    return true;
  }
  else{
    Log.Error("File does not exist : " + FILE_SAVE_PATH + fileName + '.txt');
    return false;
  }
}

function findFileTab(fileName){

  let tabList = Aliases.Notepad.wndNotepad.MicrosoftUIContentDesktopChildSiteBridge.InputSiteWindowClass.Tabs.TabListView;

  let tab = tabList.FindChild("Name","*" + fileName + "*",20);

  if(tab.Exists){
    Log.Checkpoint("Found tab : " + fileName);
    return tab;
  }

  Log.Error("Tab not found : " + fileName);
  return null;
}


function replaceAllKeyword(wordToReplace , wordWithReplace){
  let text = getEditorText();
  let updatedText = aqString.Replace(text,wordToReplace , wordWithReplace);
  enterText(updatedText);
}


function replaceFirstOccurence(wordToReplace, wordWithReplace){
  let editorText = getEditorText();

  let firstIndex = aqString.Find(
      editorText,
      wordToReplace,
      0,
      false
  );

  if(firstIndex == -1){

    Log.Error("Word not found : " + wordToReplace);
    return;
  }

  let beforeWord = aqString.SubString(
      editorText,
      0,
      firstIndex
  );

  let afterWord = aqString.SubString(
      editorText,
      firstIndex + aqString.GetLength(wordToReplace),
      aqString.GetLength(editorText)
  );

  let updatedText = beforeWord + wordWithReplace + afterWord;

  clearEditor();

  enterText(updatedText);
}


function openWindowExists(){
  return waitForExistence(Aliases.Notepad.Open);
}

