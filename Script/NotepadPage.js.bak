function enterText(text){
  logStep("Entering text into Editor.");
  
  typeText(Aliases.Notepad.wndNotepad.NotepadTextBox.RichEditD2DPT, text);
  
}

function appendText(text){
  logStep("Adding new text into editor last line.");
  
  typeText(Aliases.Notepad.wndNotepad.NotepadTextBox.RichEditD2DPT, text)
}

function clearEditor(){
  logStep("Clearing Text from Editor.");
  
  clearText(Aliases.Notepad.wndNotepad.NotepadTextBox.RichEditD2DPT);
}


function getEditorText(){
  logStep("Fetching text present in Editor.");
  
  return getElementText(Aliases.Notepad.wndNotepad.NotepadTextBox.RichEditD2DPT);
}

function selectAllText(){
  logStep("Selecting all the text from Editor.");
  
  clickElement(Aliases.Notepad.wndNotepad.NotepadTextBox.RichEditD2DPT);
  
  pressCtrlA();
}


function clickFileMenu(){
  logStep("Click File Option from Menu");
  
  clickElement(Aliases.Notepad.wndNotepad.MicrosoftUIContentDesktopChildSiteBridge.InputSiteWindowClass.MenuBar.File);
}

function createNewFile(){
  logStep("Creating new File");
  
  pressCtrlN();
}

function saveFile(){
  logStep("Saving file");
  
  pressCtrlS();
}

function saveFileAs(fileName){
  logStep("Using Save file as with name : " + fileName);
  
  pressCtrlplusS();
  
  verifyObjectExists(Aliases.Notepad.Save_as);
  
  typeText(Aliases.Notepad.Save_as.DUIViewWndClassName.Explorer_Pane.FloatNotifySink.File_name_.File_name_, fileName);
  
  clickElement(Aliases.Notepad.Save_as.Save);
}


function openFile(fileName){
  logStep("Opening a pre-existing file named as : " + fileName);
  
  logInfo("Clicking open Button");
    
  clickElement(Aliases.Notepad.wndNotepad.MicrosoftUIContentDesktopChildSiteBridge.InputSiteWindowClass.MenuBar.File.File);
  Runner.Pause();
  
  clickElement(Aliases.Notepad.PopupHost.InputSiteWindowClass.Popup.MenuFlyout.Open);
  
  typeText(Aliases.Notepad.Open.File_name_.File_name_.File_name_, fileName);
  
  clickElement(Aliases.Notepad.Open.Open);
}


